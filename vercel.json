{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "public/index.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "public/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "public/index.php"
    }
  ]
}
